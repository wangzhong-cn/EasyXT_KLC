{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "EasyXT Tauri Shell",
  "version": "0.1.0",
  "identifier": "com.easyxt.tauri-shell",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://127.0.0.1:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "EasyXT Tauri Shell",
        "width": 1680,
        "height": 960,
        "resizable": true,
        "fullscreen": false
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}