# ============================================================================
# EasyXT 量化交易平台 — 环境变量完整配置模板
# cp .env.example .env  →  按实际路径填写
# 敏感字段（账号/Token/密码）切勿提交到版本控制系统
# ============================================================================

# ── QMT 账户 ─────────────────────────────────────────────────────────────────
EASYXT_ACCOUNT_ID=your_account_id
EASYXT_PASSWORD=your_password
QMT_EXE=D:\path\to\XtItClient.exe
QMT_USERDATA=D:\path\to\userdata_mini

# ── DuckDB 路径 ───────────────────────────────────────────────────────────────
EASYXT_DUCKDB_PATH=D:\StockData\stock_data.ddb
EASYXT_DUCKDB_LEGACY_PATH=D:\StockData\stock_data.ddb

# ── 远端数据源熔断器 ──────────────────────────────────────────────────────────
EASYXT_REMOTE_CB_THRESHOLD=5
EASYXT_REMOTE_BACKOFF_BASE_S=1.0
EASYXT_REMOTE_BACKOFF_MAX_S=300.0

# ── 增量回填 ──────────────────────────────────────────────────────────────────
EASYXT_BACKFILL_ENABLED=1
EASYXT_BACKFILL_MAX_QUEUE=512
# 补数调度器死信队列文件路径（留空使用默认 data_manager/backfill_dead_letter.jsonl）
EASYXT_DEAD_LETTER_PATH=

# ── Tushare Token（pro 接口，可用于财务数据/日线补全）────────────────────────
EASYXT_TUSHARE_TOKEN=

# ── API 服务 ──────────────────────────────────────────────────────────────────
# 鉴权 Token（留空 = 不启用 Token 校验，仅开发用）
EASYXT_API_TOKEN=
# 服务监听地址（生产建议 127.0.0.1 + 反代，开发用 0.0.0.0）
EASYXT_API_HOST=127.0.0.1
EASYXT_API_PORT=8765
# 每 IP 每分钟最大请求数（0 = 不限制）
EASYXT_RATE_LIMIT=60
# WS 慢消费者超时（秒）
EASYXT_WS_TIMEOUT=0.1
# WS 每连接最大队列深度（满则丢帧）
EASYXT_WS_QUEUE_SIZE=64
# WS 丢帧率告警阈值
EASYXT_DROP_RATE_WARN=0.01
EASYXT_DROP_RATE_CRIT=0.05
EASYXT_DROP_RATE_MIN_SAMPLES=20
# 应用版本信息（CI 注入，手动部署可留 dev）
EASYXT_BUILD_VERSION=dev
EASYXT_COMMIT_SHA=unknown

# ── DAT 文件时效门限（小时）：超过此值视为过期，跳过 DAT 兜底 ──────────────
EASYXT_DAT_STALE_HOURS=24

# ── 隔离队列死信告警阈值 ──────────────────────────────────────────────────────
# 绝对数量超过 WARN 值 或 占比超过 RATIO_WARN 时触发 CRITICAL 日志
EASYXT_QUARANTINE_DEADLETTER_WARN=100
EASYXT_QUARANTINE_DEADLETTER_RATIO_WARN=0.01

# ── 跨源一致性检查（收盘后 10 分钟抽检，偏差超过阈值告警）────────────────────
EASYXT_CROSS_SOURCE_SAMPLE=30
EASYXT_CROSS_SOURCE_THRESHOLD=0.02

# ── Step6 数据验证抽样（1.0 = 全量验证，0.1 = 10% 抽样，生产可降低频次）────
EASYXT_STEP6_VALIDATE_SAMPLE_RATE=1.0
# 金丝雀写入模式（0=关闭，1=仅写影子表用于验证，不影响主表）
EASYXT_CANARY_SHADOW_WRITE=0
EASYXT_CANARY_SHADOW_ONLY=1

# ── 数据更新器批量检查点（中断后可续传）────────────────────────────────────────
# 检查点文件保存在 DuckDB 同目录，通常无需修改
# EASYXT_CHECKPOINT_PATH=D:\StockData\data_updater_checkpoint.json

# ── 日志级别（DEBUG / INFO / WARNING / ERROR）──────────────────────────────────
EASYXT_LOG_LEVEL=INFO
# 结构化日志文件路径（留空则仅输出到 stderr）
EASYXT_LOG_FILE=logs/easyxt.log
